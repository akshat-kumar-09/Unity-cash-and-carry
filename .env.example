# Database — PostgreSQL (Neon, Supabase, or local). Required for production & for `pnpm build`.
# Example (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — use your real deploy URL in production (Vercel or custom domain)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Optional: set on Vercel if Auth.js reports host errors (usually not needed; app sets trustHost)
# AUTH_TRUST_HOST=true

# App (optional; some docs reference this)
APP_URL="http://localhost:3000"

# Public marketing site — “Apply for access” on the login page opens this URL (full URL to your registration form)
# NEXT_PUBLIC_MARKETING_REGISTER_URL="https://your-website.com/register"

# Viva Wallet (Smart Checkout) — set VIVA_ENV=production only once you have live credentials
VIVA_ENV="demo"
VIVA_CLIENT_ID=""
VIVA_CLIENT_SECRET=""
VIVA_MERCHANT_ID=""
VIVA_API_KEY=""
VIVA_SOURCE_CODE=""
# Random string of your own choosing — forms part of the webhook URL, not a Viva-issued value
VIVA_WEBHOOK_SECRET=""
