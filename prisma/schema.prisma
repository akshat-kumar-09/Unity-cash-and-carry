// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  tradeCode     String?   @unique
  role          String    @default("customer") // admin, trader, customer
  walletBalance Float     @default(45.00)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  walletTransactions WalletTransaction[]
  stockSubscriptions StockSubscription[]
}

model Product {
  id            String    @id @default(cuid())
  name          String
  /// UK product information — visible description for trade listings (legal requirement for listings).
  description   String    @default("")
  brand         String
  category      String
  sku           String    @unique
  packLabel     String
  unitsPerPack  Int
  unitPrice     Float
  casePrice     Float
  /// Max cases of this SKU a customer can order per line (wholesale cap).
  maxQtyPerOrder Int      @default(100)
  badge         String?
  imageUrl      String?
  isActive      Boolean   @default(true)
  stock         Int       @default(100)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orderItems    OrderItem[]
  stockSubscriptions StockSubscription[]
}

model Order {
  id            String    @id @default(cuid())
  orderNumber   String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  status        String    @default("pending") // pending, confirmed, dispatched, delivered, cancelled
  subtotal        Float
  vat             Float
  total           Float
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  shippingAddress String?
  notes           String?
  promoCode          String?
  discountAmount     Float @default(0.00)
  walletCreditsUsed  Float @default(0.00)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  createdAt     DateTime  @default(now())
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  type        String   // "promo_reward", "order_deduction", "admin_adjustment", "deposit"
  description String
  createdAt   DateTime @default(now())
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String
  discountType  String   // "percentage", "fixed_amount"
  value         Float
  minOrderValue Float    @default(0.00)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model StockSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  email       String
  createdAt   DateTime @default(now())
  @@unique([userId, productId])
}
