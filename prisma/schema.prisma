// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  tradeCode     String?   @unique
  role          String    @default("customer") // admin, trader, customer, rep
  /// Wholesale pricing tier: "A" (most valued), "B" (valued), "C" (casual/default)
  priceTier     String    @default("C")
  walletBalance Float     @default(0.00)
  // HMRC Compliance — retailers must be verified before ordering
  vatNumber              String?
  companyNumber          String?
  companyName            String?
  postcode               String?
  retailerLicenseRef     String?
  complianceStatus       String    @default("pending")  // "pending" | "approved" | "blocked"
  complianceNotes        String?
  /// First moment complianceStatus became "approved" — drives the Trade Pass "Partner since" date. Set once, never overwritten by later re-approvals.
  approvedAt             DateTime?
  /// First-login welcome build (device assembly game) completion — null until they finish (or back out of) it. Never replayed once set.
  welcomeGameCompletedAt DateTime?
  assignedRepId          String?
  /// Saved cart (array of {productId, quantity}) — survives logout/login and device changes.
  cartData               Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  walletTransactions WalletTransaction[]
  stockSubscriptions StockSubscription[]
  capturedLeads      RetailerLead[] @relation("CapturedLeads")
  repVisits          RouteVisit[]   @relation("RepVisits")
}

model Product {
  id            String    @id @default(cuid())
  name          String
  /// UK product information — visible description for trade listings (legal requirement for listings).
  description   String    @default("")
  brand         String
  category      String
  /// Real per-brand product line from the site catalogue (e.g. "BB 4000 Kit", "600 Kit") — null for non-vape/accessory items.
  productLine   String?
  sku           String    @unique
  packLabel     String
  unitsPerPack  Int
  /// Tier C (casual/default) price — used when no tier-specific override is set.
  unitPrice     Float
  casePrice     Float
  /// Tier A (most valued retailers) override — null falls back to unitPrice/casePrice.
  unitPriceA    Float?
  casePriceA    Float?
  /// Tier B (valued retailers) override — null falls back to unitPrice/casePrice.
  unitPriceB    Float?
  casePriceB    Float?
  /// Max cases of this SKU a customer can order per line (wholesale cap).
  maxQtyPerOrder Int      @default(100)
  badge         String?
  imageUrl      String?
  isActive      Boolean   @default(true)
  /// Whether this product should appear in shop browse/search results. Distinct from
  /// isActive, which also gates cart/order validity — a hidden gift item (e.g. the
  /// welcome-build brochure) needs isActive=true (so it survives cart reload/checkout)
  /// but isCatalogueVisible=false (so it never shows up as a browsable product).
  isCatalogueVisible Boolean @default(true)
  /// Marks a gift/free item (e.g. the welcome-build pack) so cart UI can special-case it —
  /// e.g. not popping the sticky cart bar just because a gift landed in the cart.
  isGiftItem         Boolean @default(false)
  stock         Int       @default(100)
  // VPD duty fields
  liquidVolumeMl      Float     @default(2.00)
  isSubjectToVapeDuty Boolean   @default(true)
  nicotineStrengthMg  Float     @default(20.00)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orderItems    OrderItem[]
  stockSubscriptions StockSubscription[]
  warehouseExtractions WarehouseExtraction[]
}

model Order {
  id            String    @id @default(cuid())
  orderNumber   String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  status        String    @default("pending") // pending, confirmed, dispatched, delivered, cancelled
  subtotal        Float
  vat             Float
  total           Float
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  shippingAddress String?
  notes           String?
  promoCode          String?
  discountAmount     Float @default(0.00)
  walletCreditsUsed  Float @default(0.00)
  // VPD duty tracking
  vapeDutyAmount     Float @default(0.00)
  vatOnDuty          Float @default(0.00)
  // Viva Wallet (Smart Checkout) payment tracking
  paymentStatus      String    @default("unpaid") // unpaid, paid, failed
  paymentMethod      String?   // "card" (Viva) | "wallet" (fully covered by wallet credits)
  vivaOrderCode      String?   @unique
  paidAt             DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  createdAt     DateTime  @default(now())
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float
  type        String   // "promo_reward", "order_deduction", "admin_adjustment", "deposit"
  description String
  createdAt   DateTime @default(now())
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String
  discountType  String   // "percentage", "fixed_amount"
  value         Float
  minOrderValue Float    @default(0.00)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model StockSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  email       String
  createdAt   DateTime @default(now())
  @@unique([userId, productId])
}

// ─── HMRC Duty-Suspension Warehouse ─────────────────────────────────────────
// Tracks every stock extraction from the HMRC bonded warehouse.
// Duty is triggered ONLY when Unity pulls stock out for sale.
model WarehouseExtraction {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantityUnits   Int
  liquidVolumeMl  Float    // per-unit volume at time of extraction
  totalVolumeMl   Float    // quantityUnits * liquidVolumeMl
  dutyPerUnit     Float    // liquidVolumeMl * 0.22
  totalDuty       Float    // quantityUnits * dutyPerUnit
  extractedAt     DateTime @default(now())
  extractedBy     String   // admin user ID
  hmrcPeriod      String   // e.g. "2026-10" for monthly grouping
  notes           String?
}

// ─── Sales Rep CRM ──────────────────────────────────────────────────────────
// Retailer contacts captured by sales reps in the field — NOT in personal phones.
model RetailerLead {
  id              String   @id @default(cuid())
  businessName    String
  contactName     String
  phone           String
  email           String?
  address         String
  postcode        String
  city            String
  lat             Float?
  lng             Float?
  notes           String?
  status          String   @default("prospect") // "prospect" | "contacted" | "pitched" | "onboarded" | "declined"
  capturedById    String
  capturedBy      User     @relation("CapturedLeads", fields: [capturedById], references: [id])
  visits          RouteVisit[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  followUpDate    DateTime?
}

model RouteVisit {
  id              String   @id @default(cuid())
  repId           String
  rep             User     @relation("RepVisits", fields: [repId], references: [id])
  leadId          String
  lead            RetailerLead @relation(fields: [leadId], references: [id])
  visitedAt       DateTime @default(now())
  outcome         String   // "pitched" | "follow_up" | "onboarded" | "not_interested"
  notes           String?
}

model SystemSetting {
  key   String @id
  value String
}

model InviteToken {
  token     String   @id
  email     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
